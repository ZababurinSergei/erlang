{application, kafka_demo,
 [
  {description, "Kafka consumer demo with full OTP stack"},
  {vsn, "0.2.0"},
  {modules, []},
  {registered, []},
  {applications, [kernel, stdlib, brod]},
  {mod, {kafka_demo_app, []}},
  {env, [
      {kafka_hosts, [{"localhost", 9092}]},
      {client_id, my_kafka_client},
      {topic, <<"my-test-topic">>},
      {consumer_group, <<"kafka-demo-group">>}
  ]}
 ]}.