{erl_opts, [debug_info]}.

{deps, [
    {brod, "3.16.0"},
    {kafka_protocol, "4.3.4"},
    {supervisor3, "1.1.12"},
    {crc32cer, "1.1.3"},
    {snappyer, "1.2.10"},
    {pc, "1.15.0"}
]}.

{profiles, [
    {test, [{erl_opts, [nowarn_export_all]}]},
    {prod, []}
]}.

{shell, [
    {apps, [kafka_demo]},
    {config, "config/sys.config"}
]}.

{project_apps, [kafka_demo]}.

{eunit_compile_opts, []}.

{dialyzer, [
    {warnings, [no_return, unmatched_returns, error_handling]},
    {plt_extra_apps, [kernel, stdlib, crypto, ssl]},
    {plt_apps, [erts, kernel, stdlib, brod, kafka_protocol]},
    {ignore_warnings, "dialyzer_ignore.conf"}
]}.

{xref_queries, [
    {"(XC) || (XU)", []}
]}.